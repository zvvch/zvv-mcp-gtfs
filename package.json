{
  "name": "mcp-gtfs",
  "version": "2.0.0",
  "description": "MCP Server für Schweizer ÖV-Fahrplandaten (GTFS) – abfragbar via AI/LLM",
  "main": "server.js",
  "scripts": {
    "download": "node download-gtfs.js",
    "import": "node import-gtfs.js",
    "build": "node download-gtfs.js && node import-gtfs.js",
    "start": "node server.js",
    "check-update": "node check-update.js --check",
    "update": "node check-update.js",
    "force-update": "node check-update.js --force",
    "test": "node --test test/smoke.test.js"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "better-sqlite3": "^12.10.0",
    "cheerio": "^1.0.0",
    "express": "^5.2.1",
    "unzipper": "^0.12.0",
    "zod": "^3.25.0"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
