# ── Cloudflare-Bridge (Named Tunnel, komplett per CLI) ───────────
# Einmalig einrichten:
#   cloudflared tunnel login                       # Browser: Zone auswaehlen
#   cloudflared tunnel create <name>               # schreibt <UUID>.json
#   cloudflared tunnel route dns <UUID> host.dom   # DNS-Eintrag setzen
# Dann hier eintragen und: docker compose --profile tunnel up -d
#
# Die Ingress-Regel steckt in docker-compose.yml (--url http://gtfs:3000),
# es braucht also KEINE Konfiguration im Cloudflare-Dashboard.
TUNNEL_ID=
CF_CREDENTIALS_FILE=

# ── Zugriffsschutz ───────────────────────────────────────────────
# Schuetzt /mcp und /api/query per "Authorization: Bearer <token>".
# Pflicht, sobald der Dienst ueber den Tunnel oeffentlich erreichbar ist.
# Erzeugen mit: openssl rand -hex 32
MCP_AUTH_TOKEN=

# ── Netzwerk ─────────────────────────────────────────────────────
# Host-Port fuer den Dienst, gebunden an 127.0.0.1. Anpassen, falls 3000
# auf dem Host bereits belegt ist.
HOST_PORT=3000

# ── Fahrplan-Updates ─────────────────────────────────────────────
# Prueft bei jedem Start auf einen neueren Fahrplan und baut bei Bedarf neu.
GTFS_AUTO_UPDATE=true
